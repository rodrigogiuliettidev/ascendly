generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  password           String
  xp                 Int      @default(0)
  coins              Int      @default(0)
  streak             Int      @default(0)
  lastCompletionDate DateTime?
  fcmToken           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  habits             Habit[]
  habitCompletions   HabitCompletion[]
  userMissions       UserMission[]
  userAchievements   UserAchievement[]
  weeklyXp           WeeklyXp[]
  notifications      Notification[]
  notificationPrefs  NotificationPreference?
  followers          Follow[] @relation("following")
  following          Follow[] @relation("follower")
  xpLogs             XpLog[]
  challenge          Challenge?

  @@map("users")
}

model Habit {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?
  xpReward     Int      @default(25)
  coinReward   Int      @default(10)
  penaltyXp    Int      @default(5)
  reminderTime Int?
  daysOfWeek   Int[]    @default([0, 1, 2, 3, 4, 5, 6])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions HabitCompletion[]

  @@index([userId])
  @@map("habits")
}

model HabitCompletion {
  id             String   @id @default(cuid())
  habitId        String
  userId         String
  completionDate DateTime
  completedAt    DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, userId, completionDate])
  @@index([userId, completionDate])
  @@index([habitId])
  @@map("habit_completions")
}

model Mission {
  id          String      @id @default(cuid())
  title       String
  description String
  type        MissionType
  target      Int
  xpReward    Int         @default(50)
  coinReward  Int         @default(25)

  userMissions UserMission[]

  @@map("missions")
}

enum MissionType {
  COMPLETE_HABITS
  EARN_XP
  MAINTAIN_STREAK
}

model UserMission {
  id          String        @id @default(cuid())
  userId      String
  missionId   String
  progress    Int           @default(0)
  status      MissionStatus @default(IN_PROGRESS)
  assignedAt  DateTime      @default(now())
  completedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, assignedAt])
  @@index([userId, status])
  @@map("user_missions")
}

enum MissionStatus {
  IN_PROGRESS
  COMPLETED
  CLAIMED
}

model Achievement {
  id          String          @id @default(cuid())
  title       String
  description String
  type        AchievementType
  target      Int
  xpReward    Int             @default(100)
  coinReward  Int             @default(50)
  icon        String?

  userAchievements UserAchievement[]

  @@map("achievements")
}

enum AchievementType {
  FIRST_HABIT
  STREAK_7
  STREAK_30
  LEVEL_10
  TOP_10_RANKING
  HABITS_COMPLETED
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model WeeklyXp {
  id        String   @id @default(cuid())
  userId    String
  xpEarned  Int      @default(0)
  weekStart DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart, xpEarned(sort: Desc)])
  @@map("weekly_xp")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

enum NotificationType {
  HABIT_REMINDER
  RANKING_UPDATE
  STREAK_WARNING
  ACHIEVEMENT_UNLOCK
  MISSION_COMPLETE
  XP_REWARD
}

model NotificationPreference {
  id              String  @id @default(cuid())
  userId          String  @unique
  habitReminders  Boolean @default(true)
  achievements    Boolean @default(true)
  rankingUpdates  Boolean @default(true)
  streakWarnings  Boolean @default(true)
  missions        Boolean @default(true)
  pushEnabled     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model XpLog {
  id        String    @id @default(cuid())
  userId    String
  amount    Int
  type      XpLogType
  reason    String
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, type])
  @@map("xp_logs")
}

enum XpLogType {
  GAIN
  PENALTY
}

model Challenge {
  id          String    @id @default(cuid())
  userId      String    @unique
  currentDay  Int       @default(1)
  totalDays   Int       @default(30)
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("challenges")
}
